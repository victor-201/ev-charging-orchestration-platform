# ==============================================================================
# .env.example -- EV Charging Flutter Mobile App
# Template cong khai -- DUOC commit len git
# Copy thanh .env va dien gia tri thuc truoc khi chay app
# ==============================================================================

# -- Moi truong ----------------------------------------------------------------
FLAVOR=dev
# dev | staging | prod

# -- API Backend ---------------------------------------------------------------
# Chay backend local roi lay IP LAN cua may: ipconfig -> IPv4
# Thiet bi that (USB)
API_BASE_URL=http://<LAN-IP>:8000

# Android Emulator
# API_BASE_URL=http://10.0.2.2:8000

# Staging
# API_BASE_URL=http://staging.ev-charging.local:8000

# Production
# API_BASE_URL=https://api.ev-charging.vn

# -- WebSocket (Socket.IO realtime) -------------------------------------------
# Mac dinh: wsBaseUrl duoc derive tu API_BASE_URL
# Ngan route: /socket.io/charging -> session-service:3004
# VD local: WEBSOCKET_URL=ws://192.168.1.10:8000/socket.io/charging
# VD ngrok: WEBSOCKET_URL=wss://xxx.ngrok-free.dev/socket.io/charging
# WEBSOCKET_URL=

# -- Firebase ------------------------------------------------------------------
# Buoc 1: Vao https://console.firebase.google.com
# Buoc 2: Tao project -> Add Android app -> package: com.evcharging.ev_charging_app
# Buoc 3: Tai google-services.json -> dat vao android/app/
FIREBASE_PROJECT_ID=<your-firebase-project-id>

# -- VNPay (Thanh toan) --------------------------------------------------------
VNPAY_RETURN_SCHEME=ev://app/wallet/topup/processing

# -- Deep Link -----------------------------------------------------------------
DEEP_LINK_SCHEME=ev
DEEP_LINK_HOST=app

# -- OpenRouteService (Ban do - Dinh tuyen) ------------------------------------
# Dang ky mien phi tai: https://openrouteservice.org/dev/#/signup
# Khong co key -> dung demo key tu dong (500 req/ngay)
ORS_API_KEY=<your-ors-api-key>
