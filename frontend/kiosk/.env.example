# EVOLTTOUCH Kiosk Environment Variables Example
#
# Port convention:
#   Web-admin :5000 (Next.js)
#   Kiosk     :5001 (Vite)
#   Kong API  :8000  (backend gateway — proxied via Vite in dev)

# Backend API Base URL (relative path → Vite proxy → Kong)
VITE_API_BASE_URL=/api/v1

# WebSocket URL for real-time telemetry
VITE_WS_URL=ws://localhost:8000/ws/telemetry

# Station ID (bắt buộc) — trạm sạc của kiosk
VITE_STATION_ID=EV-XXXX-XXXX

# Trụ/Pillar và Charger có thể để trống, sẽ chọn trên màn hình Welcome
# VITE_POINT_ID=PT-XXXX-XXXX
# VITE_CHARGER_ID=CHG-XXXX-XXXX

# Feature Flags
VITE_ENABLE_MOCK_DATA=true
VITE_AUTO_START_KIOSK=true
