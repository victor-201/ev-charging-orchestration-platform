{
    "name": "booking-service",
    "version": "1.0.0",
    "description": "EV Charging — Booking Engine (Core Service)",
    "dependencies": {
        "@golevelup/nestjs-rabbitmq": "^9.0.0",
        "@nestjs/axios": "^4.0.1",
        "@nestjs/common": "^10.4.0",
        "@nestjs/config": "^3.2.0",
        "@nestjs/core": "^10.4.0",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/microservices": "^10.4.0",
        "@nestjs/platform-express": "^10.4.0",
        "@nestjs/platform-socket.io": "^10.4.0",
        "@nestjs/schedule": "^4.1.0",
        "@nestjs/swagger": "^11.4.2",
        "@nestjs/typeorm": "^11.0.0",
        "@nestjs/websockets": "^10.4.0",
        "@opentelemetry/auto-instrumentations-node": "^0.73.0",
        "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
        "@opentelemetry/resources": "^2.7.0",
        "@opentelemetry/sdk-node": "^0.215.0",
        "@opentelemetry/semantic-conventions": "^1.40.0",
        "@willsoto/nestjs-prometheus": "^6.1.0",
        "amqp-connection-manager": "^4.1.14",
        "amqplib": "^0.10.4",
        "axios": "^1.15.2",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "ioredis": "^5.4.1",
        "jsonwebtoken": "^9.0.3",
        "nestjs-pino": "^4.6.1",
        "pg": "^8.12.0",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "prom-client": "^15.1.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "socket.io": "^4.7.5",
        "swagger-ui-express": "^5.0.1",
        "typeorm": "^0.3.20",
        "uuid": "^10.0.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.4.0",
        "@nestjs/testing": "^10.4.0",
        "@types/amqplib": "^0.10.5",
        "@types/jest": "^29.5.13",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.0.0",
        "@types/pg": "^8.11.6",
        "@types/uuid": "^10.0.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.6.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testMatch": [
            "<rootDir>/test/unit/**/*.spec.ts",
            "<rootDir>/test/integration/**/*.spec.ts",
            "<rootDir>/test/e2e/**/*.spec.ts"
        ],
        "transform": {
            "^.+\\.(t|j)s$": [
                "ts-jest",
                {
                    "tsconfig": "tsconfig.json"
                }
            ]
        },
        "testEnvironment": "node",
        "coverageDirectory": "./coverage",
        "collectCoverageFrom": [
            "src/**/*.ts",
            "!src/main.ts",
            "!src/tracing.ts",
            "!src/**/*.module.ts",
            "!src/**/*.d.ts"
        ],
        "coverageReporters": [
            "text",
            "lcov",
            "html"
        ],
        "moduleNameMapper": {
            "^@domain/(.*)$": "<rootDir>/src/domain/$1",
            "^@application/(.*)$": "<rootDir>/src/application/$1",
            "^@infrastructure/(.*)$": "<rootDir>/src/infrastructure/$1",
            "^@shared/(.*)$": "<rootDir>/src/shared/$1"
        }
    },
    "scripts": {
        "build": "nest build",
        "start": "node dist/main",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "lint": "eslint \"{src,test}/**/*.ts\"",
        "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
        "migration:run": "npm run typeorm -- migration:run -d src/infrastructure/persistence/typeorm/data-source.ts",
        "migration:revert": "npm run typeorm -- migration:revert -d src/infrastructure/persistence/typeorm/data-source.ts",
        "test": "jest --config jest.config.js --passWithNoTests",
        "test:unit": "jest --config jest.config.js --testPathPattern=test/unit --passWithNoTests",
        "test:integration": "jest --config jest.config.js --testPathPattern=test/integration --passWithNoTests",
        "test:e2e": "jest --config jest.config.js --testPathPattern=test/e2e --passWithNoTests",
        "test:cov": "jest --config jest.config.js --coverage --passWithNoTests",
        "test:watch": "jest --config jest.config.js --watch"
    }
}
