{
    "name": "ocpp-gateway-service",
    "version": "1.0.0",
    "description": "OCPP 1.6J WebSocket Gateway — bridges physical EV chargers to the platform",
    "dependencies": {
        "@golevelup/nestjs-rabbitmq": "^9.0.0",
        "@nestjs/common": "^10.4.0",
        "@nestjs/config": "^3.2.0",
        "@nestjs/core": "^10.4.0",
        "@nestjs/platform-express": "^10.4.0",
        "@nestjs/platform-socket.io": "^10.4.0",
        "@nestjs/schedule": "^4.1.0",
        "@nestjs/swagger": "^11.4.2",
        "@nestjs/websockets": "^10.4.0",
        "@opentelemetry/auto-instrumentations-node": "^0.73.0",
        "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
        "@opentelemetry/resources": "^2.7.0",
        "@opentelemetry/sdk-node": "^0.215.0",
        "@opentelemetry/semantic-conventions": "^1.40.0",
        "@willsoto/nestjs-prometheus": "^6.1.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "jsonwebtoken": "^9.0.3",
        "nestjs-pino": "^4.6.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "prom-client": "^15.1.3",
        "reflect-metadata": "^0.1.14",
        "rxjs": "^7.8.1",
        "socket.io": "^4.7.5",
        "swagger-ui-express": "^5.0.1",
        "uuid": "^9.0.1",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@nestjs/testing": "^10.4.22",
        "@types/jest": "^29.5.14",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.0.0",
        "@types/uuid": "^9.0.7",
        "@types/ws": "^8.5.10",
        "jest": "^29.7.0",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.4.5"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testMatch": [
            "<rootDir>/test/unit/**/*.spec.ts",
            "<rootDir>/test/integration/**/*.spec.ts",
            "<rootDir>/test/e2e/**/*.spec.ts"
        ],
        "transform": {
            "^.+\\.(t|j)s$": [
                "ts-jest",
                {
                    "tsconfig": "tsconfig.json"
                }
            ]
        },
        "testEnvironment": "node",
        "coverageDirectory": "./coverage",
        "collectCoverageFrom": [
            "src/**/*.ts",
            "!src/main.ts",
            "!src/tracing.ts",
            "!src/**/*.module.ts",
            "!src/**/*.d.ts"
        ],
        "coverageReporters": [
            "text",
            "lcov",
            "html"
        ]
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "start": "node dist/main",
        "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
        "lint": "eslint \"{src,test}/**/*.ts\"",
        "test:e2e": "jest --config jest.config.js --testPathPattern=test/e2e --passWithNoTests",
        "test:watch": "jest --config jest.config.js --watch",
        "test": "jest --config jest.config.js --passWithNoTests",
        "test:unit": "jest --config jest.config.js --testPathPattern=test/unit --passWithNoTests",
        "test:integration": "jest --config jest.config.js --testPathPattern=test/integration --passWithNoTests",
        "test:cov": "jest --config jest.config.js --coverage --passWithNoTests"
    }
}
