# ==============================================================================
# iam-service - .env.example
# ==============================================================================

# Application
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# Database
DB_HOST=postgres-iam
DB_PORT=5432
DB_USER=ev_user
DB_PASSWORD=ev_secret
DB_NAME=ev_iam_db

# Redis (Session Revocation Store)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBITMQ_URL=amqp://ev_user:ev_secret@rabbitmq:5672

# Cloudinary (Avatar upload)
CLOUDINARY_CLOUD_NAME=drpl0qtfo
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Auth / JWT
# IAM Service is the ONLY service that requires the RS256 Private Key
JWT_PRIVATE_KEY_PATH=/var/run/secrets/jwt_private.pem
# Example inline key (escape newlines with \n):
# JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY_PATH=/var/run/secrets/jwt_public.pem
JWT_ISSUER=ev-iam-service
JWT_AUDIENCE=ev-platform
JWT_EXPIRES_IN=900s
JWT_REFRESH_EXPIRES_IN=604800s
